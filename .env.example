# ============================================================================
# MontgoPulse Environment Variables
# ============================================================================

# ---- ArcGIS (Montgomery Open Data Portal) ----
# Full GeoJSON endpoint URLs — fetched directly via fetch()
ARCGIS_BUSINESS_LICENSE_URL=https://gis.montgomeryal.gov/server/rest/services/HostedDatasets/Business_License/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson
ARCGIS_CRIME_URL=https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/911_Calls_Data/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson
ARCGIS_PERMITS_URL=
ARCGIS_VIOLATIONS_URL=

# ---- Bright Data Scraping Browser ----
# WebSocket endpoint for puppeteer-core connection
# Format: wss://brd-customer-<CUSTOMER_ID>-zone-scraping_browser1:<PASSWORD>@brd.superproxy.io:9222
BRIGHT_DATA_WS_ENDPOINT=your-endpoint-here

# ---- AI Copilot ----
AI_API_KEY=your-api-key-here
