# ==============================================================================
# MontgoPulse | Environment Configuration
# ==============================================================================
# Usage: Copy this file to `.env.local` and populate the required secrets.

# --- ArcGIS Public Endpoints (Montgomery Open Data) ---
# No authentication required. Pre-configured for immediate data fetching.
ARCGIS_BUSINESS_LICENSE_URL="https://gis.montgomeryal.gov/server/rest/services/HostedDatasets/Business_License/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson"
ARCGIS_CRIME_URL="https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/911_Calls_Data/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson"
ARCGIS_PERMITS_URL="https://gis.montgomeryal.gov/server/rest/services/HostedDatasets/Construction_Permits/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson"
ARCGIS_VIOLATIONS_URL="https://gis.montgomeryal.gov/server/rest/services/HostedDatasets/Code_Violations/FeatureServer/0/query?outFields=*&where=1%3D1&f=geojson"

# --- Bright Data Integration ---
# WebSocket endpoint for Scraping Browser. 
# Format: wss://[credentials]@brd.superproxy.io:9222
BRIGHT_DATA_WS_ENDPOINT=""

# --- AI Engine (Google Gemini) ---
# Gemini API key required for Copilot and Procedural Reporting.
AI_API_KEY=""